font-family = JetBrains Mono
font-style  = Medium
font-size   = 13
theme       = Catppuccin Macchiato

# macOS specific configuration
macos-icon          = xray
macos-option-as-alt = true

# Remove notification badge from the dock icon
bell-features = title,no-attention

# Do not dim inactive splits
unfocused-split-opacity = 1

# Do not restore size from previous window
window-width  = 120
window-height = 40

# Balance padding on window edges
window-padding-balance  = true

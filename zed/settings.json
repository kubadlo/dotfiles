{
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 13,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 250,
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "languages": {
    "JavaScript": {
      "language_servers": [
        "tsgo",
        "!vtsls",
        "!typescript-language-server",
        "...",
      ],
    },
    "TypeScript": {
      "language_servers": [
        "tsgo",
        "!vtsls",
        "!typescript-language-server",
        "...",
      ],
    },
    "TSX": {
      "language_servers": [
        "tsgo",
        "!vtsls",
        "!typescript-language-server",
        "...",
      ],
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
          "extraArgs": ["--", "-W", "clippy::pedantic"],
        },
      },
    },
  },
  "project_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "git_panel": {
    "dock": "left",
    "default_width": 320,
    "tree_view": true,
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
}

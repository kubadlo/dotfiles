{
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 13,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
  },
  "which_key": {
    "enabled": true,
    "delay_ms": 250,
  },
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "edit_predictions": {
    "mode": "subtle",
  },
  "project_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "git_panel": {
    "dock": "left",
    "default_width": 320,
    "tree_view": true,
  },
  "outline_panel": {
    "dock": "left",
    "default_width": 320,
  },
  "collaboration_panel": {
    "button": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
}
